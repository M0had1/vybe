{
  "expo": {
    "name": "Vybe",
    "slug": "vybe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "vybe",
    "splash": { "backgroundColor": "#0A0A0F" },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vybe.app"
    },
    "android": {
      "package": "com.vybe.app",
      "adaptiveIcon": { "backgroundColor": "#0A0A0F" }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "will-be-set-after-eas-init"
      }
    },
    "plugins": ["expo-router"]
  }
}
